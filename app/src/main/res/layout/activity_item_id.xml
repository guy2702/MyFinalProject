<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F2"
    tools:context=".ItemId">

    <ImageView
        android:id="@+id/backgroundImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/backhome1"
        android:scaleType="centerCrop"
        android:alpha="0.2"
        android:clickable="false"
        android:focusable="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/btnDeleteItem"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingTop="30dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="16dp"
                    android:background="#FFFFFF">

                    <ImageView
                        android:id="@+id/ivItemImageDetail"
                        android:layout_width="match_parent"
                        android:layout_height="150dp"
                        android:layout_marginTop="8dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_launcher_foreground"/>

                    <TextView
                        android:id="@+id/tvItemNameDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:textSize="26sp"
                        android:textColor="#2C3E50"
                        android:gravity="center"
                        android:layout_marginTop="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/tvItemTypeDetail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="#E1F5FE"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:textColor="#0277BD"
                            android:textStyle="bold"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/tvItemGoalDetail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="#FFF9C4"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:textColor="#F57F17"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="24dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="6dp"><TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="קלוריות:" android:textStyle="bold" android:textColor="#34495E"/><TextView android:id="@+id/tvItemCaloriesDetail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#000000"/></LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="6dp"><TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="חלבון:" android:textStyle="bold" android:textColor="#34495E"/><TextView android:id="@+id/tvItemProteinDetail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#000000"/></LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="6dp"><TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="שומן:" android:textStyle="bold" android:textColor="#34495E"/><TextView android:id="@+id/tvItemFatDetail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#000000"/></LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="6dp"><TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="פחמימות:" android:textStyle="bold" android:textColor="#34495E"/><TextView android:id="@+id/tvItemCarbsDetail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#000000"/></LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"><TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="סוכר:" android:textStyle="bold" android:textColor="#34495E"/><TextView android:id="@+id/tvItemSugarDetail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#000000"/></LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:background="#FFFFFF">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="עריכת פרטים"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#2C3E50"
                        android:layout_marginBottom="24dp"
                        android:gravity="center"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                        <TextView android:layout_width="85dp" android:layout_height="wrap_content" android:text="שם:" android:textStyle="bold" android:textColor="#34495E"/>
                        <EditText android:id="@+id/etName" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="10dp" android:backgroundTint="#1181D4FA" android:background="@android:drawable/editbox_background_normal"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                        <TextView android:layout_width="85dp" android:layout_height="wrap_content" android:text="סוג:" android:textStyle="bold" android:textColor="#34495E"/>
                        <Spinner android:id="@+id/spinnerType" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@android:drawable/btn_dropdown" android:padding="10dp" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                        <TextView android:layout_width="85dp" android:layout_height="wrap_content" android:text="מטרה:" android:textStyle="bold" android:textColor="#34495E"/>
                        <RadioGroup android:id="@+id/rgGoal" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                            <RadioButton android:id="@+id/rbMuscle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="מסה" />
                            <RadioButton android:id="@+id/rbCut" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="חיטוב" android:layout_marginStart="24dp" />
                        </RadioGroup>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginBottom="16dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="85dp" android:layout_height="wrap_content" android:text="קלוריות:" android:textStyle="bold" android:textColor="#34495E"/>
                        <EditText android:id="@+id/etCalories" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:padding="10dp" android:backgroundTint="#11E1F5FE" android:background="@android:drawable/editbox_background_normal"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="85dp" android:layout_height="wrap_content" android:text="חלבון:" android:textStyle="bold" android:textColor="#34495E"/>
                        <EditText android:id="@+id/etProtein" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:padding="10dp" android:backgroundTint="#11E1F5FE" android:background="@android:drawable/editbox_background_normal"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="85dp" android:layout_height="wrap_content" android:text="שומן:" android:textStyle="bold" android:textColor="#34495E"/>
                        <EditText android:id="@+id/etFat" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:padding="10dp" android:backgroundTint="#11E1F5FE" android:background="@android:drawable/editbox_background_normal"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="85dp" android:layout_height="wrap_content" android:text="פחמימות:" android:textStyle="bold" android:textColor="#34495E"/>
                        <EditText android:id="@+id/etCarbs" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:padding="10dp" android:backgroundTint="#11E1F5FE" android:background="@android:drawable/editbox_background_normal"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="24dp">
                        <TextView android:layout_width="85dp" android:layout_height="wrap_content" android:text="סוכר:" android:textStyle="bold" android:textColor="#34495E"/>
                        <EditText android:id="@+id/etSugar" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:padding="10dp" android:backgroundTint="#11E1F5FE" android:background="@android:drawable/editbox_background_normal"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnUpdateItem"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="שמור שינויים"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:paddingVertical="12dp"
                        android:backgroundTint="#81D4FA"
                        android:textColor="#000000" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnDeleteItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="מחק מוצר מהמערכת"
        android:textStyle="bold"
        android:textSize="16sp"
        android:paddingVertical="14dp"
        android:textColor="#000000"
        android:backgroundTint="#B3E5FC"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>