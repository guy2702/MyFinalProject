<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F2"
    tools:context=".UserDetails">

    <!-- תמונת רקע -->
    <ImageView
        android:id="@+id/backgroundImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/backhome1"
        android:scaleType="centerCrop"
        android:alpha="0.2"
        android:clickable="false"
        android:focusable="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/btnDeleteUser"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingTop="50dp">

            <!-- כרטיסיית עריכה מסודרת עם כותרות -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:background="#FFFFFF">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="פרטי משתמש"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#2C3E50"
                        android:layout_marginBottom="24dp"
                        android:gravity="center"/>

                    <!-- שם פרטי -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                        <TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="שם פרטי:" android:textStyle="bold" android:textColor="#34495E"/>
                        <EditText android:id="@+id/tvUserFirstNameDetail" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="10dp" android:backgroundTint="#1181D4FA" android:background="@android:drawable/editbox_background_normal"/>
                    </LinearLayout>

                    <!-- שם משפחה -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                        <TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="שם משפחה:" android:textStyle="bold" android:textColor="#34495E"/>
                        <EditText android:id="@+id/tvUserLastNameDetail" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="10dp" android:backgroundTint="#1181D4FA" android:background="@android:drawable/editbox_background_normal"/>
                    </LinearLayout>

                    <!-- טלפון -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                        <TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="טלפון:" android:textStyle="bold" android:textColor="#34495E"/>
                        <EditText android:id="@+id/tvUserPhoneDetail" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="phone" android:padding="10dp" android:backgroundTint="#1181D4FA" android:background="@android:drawable/editbox_background_normal"/>
                    </LinearLayout>

                    <!-- סיסמה -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="24dp">
                        <TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="סיסמה:" android:textStyle="bold" android:textColor="#34495E"/>
                        <EditText android:id="@+id/tvUserPasswordDetail" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="textPassword" android:padding="10dp" android:backgroundTint="#1181D4FA" android:background="@android:drawable/editbox_background_normal"/>
                    </LinearLayout>

                    <!-- כפתור שמירה בתכלת בהיר גוון 1 -->
                    <Button
                        android:id="@+id/btnUpdateUser"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="שמור שינויים"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:paddingVertical="12dp"
                        android:backgroundTint="#81D4FA"
                        android:textColor="#000000" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <!-- כפתור מחיקה בתכלת בהיר גוון 2 (נעוץ למטה) -->
    <Button
        android:id="@+id/btnDeleteUser"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="מחק משתמש מהמערכת"
        android:textStyle="bold"
        android:textSize="16sp"
        android:paddingVertical="14dp"
        android:textColor="#000000"
        android:backgroundTint="#B3E5FC"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>