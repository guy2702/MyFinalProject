<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F2"
    tools:context=".register">

    <ImageView
        android:id="@+id/backgroundImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/backhome1"
        android:alpha="0.3"
        android:contentDescription="רקע מטושטש של פירות להכנת שייקים בריאותיים"
        android:clickable="false"
        android:focusable="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/textTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="הרשמה"
        android:textSize="32sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="#2C3E50"
        android:layout_marginTop="60dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/inputContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="40dp"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/textTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/firstname"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="שם פרטי"
            android:inputType="textPersonName"
            android:gravity="start|center_vertical"
            android:padding="16dp"
            android:layout_marginBottom="10dp"
            android:textColor="#000000"
            android:textColorHint="#88000000"
            android:backgroundTint="#1181D4FA"
            android:background="@android:drawable/editbox_background_normal"/>

        <EditText
            android:id="@+id/lastname"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="שם משפחה"
            android:inputType="textPersonName"
            android:gravity="start|center_vertical"
            android:padding="16dp"
            android:layout_marginBottom="10dp"
            android:textColor="#000000"
            android:textColorHint="#88000000"
            android:backgroundTint="#114FC3F7"
            android:background="@android:drawable/editbox_background_normal"/>

        <EditText
            android:id="@+id/email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="אימייל"
            android:inputType="textEmailAddress"
            android:gravity="start|center_vertical"
            android:padding="16dp"
            android:layout_marginBottom="10dp"
            android:textColor="#000000"
            android:textColorHint="#88000000"
            android:backgroundTint="#11E1F5FE"
            android:background="@android:drawable/editbox_background_normal"/>

        <EditText
            android:id="@+id/phone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="טלפון"
            android:inputType="phone"
            android:gravity="start|center_vertical"
            android:padding="16dp"
            android:layout_marginBottom="10dp"
            android:textColor="#000000"
            android:textColorHint="#88000000"
            android:backgroundTint="#11B3E5FC"
            android:background="@android:drawable/editbox_background_normal"/>

        <EditText
            android:id="@+id/password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="סיסמה"
            android:inputType="textPassword"
            android:gravity="start|center_vertical"
            android:padding="16dp"
            android:layout_marginBottom="10dp"
            android:textColor="#000000"
            android:textColorHint="#88000000"
            android:backgroundTint="#11E0F7FA"
            android:background="@android:drawable/editbox_background_normal"/>

    </LinearLayout>

    <Button
        android:id="@+id/btn_register_register"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="הירשם"
        android:textStyle="bold"
        android:textSize="18sp"
        android:paddingVertical="14dp"
        android:layout_marginHorizontal="40dp"
        android:layout_marginTop="32dp"
        android:backgroundTint="#4481D4FA"
        android:textColor="#000000"
        app:layout_constraintTop_toBottomOf="@id/inputContainer" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="לחצן להרשמה לאפליקציה FitShake"/>

    <TextView
        android:id="@+id/tv_register_login"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="כבר יש לך משתמש? לחץ כאן"
        android:textSize="16sp"
        android:textColor="#34495E"
        android:layout_marginTop="20dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/btn_register_register"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>