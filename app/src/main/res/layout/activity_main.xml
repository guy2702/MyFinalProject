<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F2"
    >

    <ImageView
        android:id="@+id/backgroundImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/backhome1"
        android:alpha="0.3"
        android:contentDescription="רקע מטושטש של פירות לשייקים"
        android:clickable="false"
        android:focusable="false"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal|top"
        android:padding="24dp"
        android:paddingTop="60dp"> <ImageView
        android:id="@+id/logoImageView"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_marginBottom="16dp"
        android:contentDescription="לוגו האפליקציה FitShake"
        android:src="@drawable/logo1" />

        <TextView
            android:id="@+id/textViewTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="הכנת שייקים בריאותיים"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="100dp" android:gravity="center"/>

        <Button
            android:id="@+id/btnSignUp"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="הרשמה"
            android:textStyle="bold"
            android:textSize="18sp"
            android:backgroundTint="#4481D4FA"
            android:textColor="#000000"
            android:layout_marginBottom="16dp"
            android:contentDescription="לחצן להרשמה לאפליקציה" />

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="התחברות"
            android:textStyle="bold"
            android:textSize="18sp"
            android:backgroundTint="#444FC3F7"
            android:textColor="#000000"
            android:layout_marginBottom="16dp"
            android:contentDescription="לחצן להתחברות לחשבון קיים" />

        <Button
            android:id="@+id/btnAbout"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="אודות"
            android:textStyle="bold"
            android:textSize="18sp"
            android:backgroundTint="#44E1F5FE"
            android:textColor="#000000"
            android:contentDescription="לחצן למידע על האפליקציה" />

    </LinearLayout>

</FrameLayout>