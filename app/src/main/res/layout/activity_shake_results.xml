<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F2"
    tools:context=".ShakeResults">

  <!-- תמונת רקע שקופה (backhome1) -->
  <ImageView
      android:id="@+id/backgroundImage"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:src="@drawable/backhome1"
      android:scaleType="centerCrop"
      android:alpha="0.2"
      android:clickable="false"
      android:focusable="false"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent" />

  <!-- פאנל עליון עם כותרת -->
  <LinearLayout
      android:id="@+id/headerLayout"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:paddingTop="32dp"
      android:paddingBottom="16dp"
      android:gravity="center"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="סיכום נתונים"
        android:textColor="#34495E"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvPageTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="24dp"
        android:gravity="center"
        android:text="השייק שבנית"
        android:textColor="#2C3E50"
        android:textSize="28sp"
        android:textStyle="bold" />
  </LinearLayout>

  <!-- אזור מרכזי - הצגת התוצאות בתוך כרטיסייה לבנה יוקרתית -->
  <androidx.cardview.widget.CardView
      android:id="@+id/cardResults"
      android:layout_width="0dp"
      android:layout_height="0dp"
      android:layout_marginHorizontal="24dp"
      android:layout_marginBottom="24dp"
      app:cardCornerRadius="24dp"
      app:cardElevation="6dp"
      app:layout_constraintTop_toBottomOf="@id/headerLayout"
      app:layout_constraintBottom_toTopOf="@+id/bottomButtonsLayout"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF">

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical"
          android:padding="32dp">

        <TextView
            android:id="@+id/tvResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:lineSpacingExtra="12dp"
            android:text="טוען תוצאות..."
            android:textColor="#1B263B"
            android:textSize="22sp"
            android:textStyle="bold" />
      </LinearLayout>
    </ScrollView>
  </androidx.cardview.widget.CardView>

  <!-- אזור תחתון - כפתורי ניווט ושמירה מסודרים בטור -->
  <LinearLayout
      android:id="@+id/bottomButtonsLayout"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:paddingHorizontal="24dp"
      android:paddingBottom="24dp"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent">

    <!-- כפתור שמירה (מודגש) -->
    <Button
        android:id="@+id/btnSaveShake"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_marginBottom="12dp"
        android:text="שמור את השייק"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="#81D4FA" />

    <!-- כפתור חזרה הביתה -->
    <Button
        android:id="@+id/btnHomeNoSave"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginBottom="12dp"
        android:text="חזרה לדף הבית בלי לשמור"
        android:textColor="#0288D1"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#E1F5FE" />

    <!-- כפתור הקודם -->
    <Button
        android:id="@+id/btnBackToNuts"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="חזרה לאגוזים"
        android:textColor="#7F8C8D"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#F2F4F4" />

  </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>